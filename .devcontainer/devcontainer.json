{
	"name": "Power-Paint Web Dev",
	"dockerComposeFile": ["../docker-compose.yml", "docker-compose.devcontainer.yml"],
	"service": "web",
	"mounts": [
		{
			"type": "bind",
			"source": "${localWorkspaceFolder}/Power-Paint/..",
			"target": "/workspaces/Power-Paint"
		}
	],
	"workspaceFolder": "/workspaces/Power-Paint",
	"remoteUser": "root",

	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash"
			},
			"extensions": [
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"bradlc.vscode-tailwindcss",
				"Prisma.prisma"
			]
		}
	}
}
