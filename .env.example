# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://postgres:your_password@db:5432/power-paint-db?schema=public&sslmode=disable
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_PORT=5432
POSTGRES_DB=power-paint-db

# ==========================================
# MIGRATOR
# ==========================================
RUN_SEED=false
# DATABASE_URL

# ==========================================
# WEB (Next.js Application)
# ==========================================
# DATABASE_URL

# Google OAuth credentials
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# GitHub OAuth credentials
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret

# NextAuth secret and URL
AUTH_SECRET=your_auth_secret
AUTH_URL=http://localhost

# WS_TOKEN_SECRET

# Base URLs
NEXT_PUBLIC_WS_URL=ws://localhost/api/socket
NEXT_PUBLIC_BASE_URL=http://localhost
NEXT_PUBLIC_BASE_DEPLOY_URL=https://your-deploy-url.com

# Email configuration
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_LOGIN=your_email@example.com
EMAIL_PASSWORD=your_email_password

# React Query Devtools
REACT_QUERY_DEVTOOLS_ENABLED=false

# Node environment
NODE_OPTIONS="--dns-result-order=ipv4first"
NODE_ENV=production

WEB_HOST=host.docker.internal # localhost
WEB_PORT=3000

# ==========================================
# SOCKET (Hocuspocus WebSocket Server)
# ==========================================
POSTGRES_SCHEMA=public
WS_TOKEN_SECRET=your_ws_token_secret
HOCUSPOCUS_DOCUMENTS_TABLE=yjs_documents
DATABASE_SSL_REJECT_UNAUTHORIZED=true
SOCKET_HOST=socket
SOCKET_PORT=3001

# ==========================================
# NGINX
# ==========================================

DOMAIN=power-paint.duckdns.org
# WEB_HOST
# WEB_PORT
# SOCKET_HOST
# SOCKET_PORT
