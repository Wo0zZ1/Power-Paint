# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://username:password@db:5432/database_name?schema=public&sslmode=disable
POSTGRES_USER=username
POSTGRES_PASSWORD=password
POSTGRES_DB=database_name
POSTGRES_PORT=5432
POSTGRES_SCHEMA=public
POSTGRES_SSLMODE=disable

# ==========================================
# MIGRATOR
# ==========================================
RUN_SEED=false

# ==========================================
# WEB (Next.js Application)
# ==========================================
NODE_ENV=development
NEXT_PUBLIC_WS_URL=ws://localhost/socket
NEXT_PUBLIC_BASE_URL=http://localhost
NEXT_PUBLIC_BASE_DEPLOY_URL=https://your-deploy-url.com
WEB_PORT=3000

AUTH_SECRET=your_auth_secret_here
AUTH_GOOGLE_ID=your_google_id_here
AUTH_GOOGLE_SECRET=your_google_secret_here
AUTH_GITHUB_ID=your_github_id_here
AUTH_GITHUB_SECRET=your_github_secret_here

EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_LOGIN=your_email@example.com
EMAIL_PASSWORD=your_email_password

REACT_QUERY_DEVTOOLS_ENABLED=true
NODE_OPTIONS="--dns-result-order=ipv4first"

# ==========================================
# SOCKET (Hocuspocus WebSocket Server)
# ==========================================
SOCKET_PORT=3001
WS_TOKEN_SECRET=your_ws_token_secret_here
HOCUSPOCUS_DOCUMENTS_TABLE=yjs_documents
DATABASE_SSL_REJECT_UNAUTHORIZED=true
